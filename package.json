{
  "name": "liquid-glass-workspace",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "node ./scripts/run-workspaces.mjs build",
    "changeset": "changeset",
    "publish-packages": "node ./scripts/publish-packages.mjs publish",
    "release": "node ./scripts/publish-packages.mjs release",
    "sync-versions": "node ./scripts/publish-packages.mjs sync",
    "typecheck": "node ./scripts/run-workspaces.mjs typecheck",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@jridgewell/trace-mapping": "^0.3.25",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.1.7",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-vue": "^5.2.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "svelte": "^5.34.9",
    "svelte-check": "^4.1.7",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vue": "^3.5.13"
  }
}
