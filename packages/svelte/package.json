{
  "name": "@lollipopkit/liquid-glass-svelte",
  "version": "0.1.2",
  "description": "Svelte liquid glass components for Vite projects.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lollipopkit/liquid-glass.git",
    "directory": "packages/svelte"
  },
  "homepage": "https://github.com/lollipopkit/liquid-glass#readme",
  "bugs": {
    "url": "https://github.com/lollipopkit/liquid-glass/issues"
  },
  "keywords": [
    "liquid-glass",
    "svelte",
    "components",
    "svg-filter",
    "visual-effects"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && node ../../scripts/copy-file.mjs src/index.d.ts dist/index.d.ts",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@lollipopkit/liquid-glass": "0.1.2"
  },
  "peerDependencies": {
    "@lollipopkit/liquid-glass-vite": "0.1.2",
    "svelte": "^5.0.0"
  }
}
