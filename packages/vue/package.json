{
  "name": "@lollipopkit/liquid-glass-vue",
  "version": "0.2.1",
  "description": "Vue liquid glass components with optional Vite asset optimization.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lollipopkit/liquid-glass.git",
    "directory": "packages/vue"
  },
  "homepage": "https://github.com/lollipopkit/liquid-glass#readme",
  "bugs": {
    "url": "https://github.com/lollipopkit/liquid-glass/issues"
  },
  "keywords": [
    "liquid-glass",
    "vue",
    "components",
    "svg-filter",
    "visual-effects"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json && node ../../scripts/flatten-dist-types.mjs dist/vue/src dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@lollipopkit/liquid-glass": "0.2.1"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}
