{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@lollipopkit/liquid-glass": [
        "../core/src/index.ts"
      ],
      "@lollipopkit/liquid-glass/*": [
        "../core/src/*"
      ]
    },
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "outDir": "./dist"
  },
  "include": [
    "src"
  ]
}
